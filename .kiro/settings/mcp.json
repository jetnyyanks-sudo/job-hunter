{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_JOBHUNTER_PAT}"
      },
      "disabled": false,
      "autoApprove": [
        "create_or_update_file"
      ]
    }
  }
}